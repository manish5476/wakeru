generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum TransactionType {
  income
  expense
  transfer
  trip_expense
  settlement_paid
  settlement_received
}

enum RecurringFrequency {
  daily
  weekly
  monthly
  yearly
}

enum PaymentMethod {
  Cash
  Card
  UPI
  Net_Banking @map("Net Banking")
  Wallet
  Other
}

enum DebtType {
  lent
  borrowed
}

enum DebtStatus {
  pending
  settled
}

// ============================================================
// MODELS
// ============================================================

model Transaction {
  id                  String             @id @default(uuid())
  userId              String             
  type                TransactionType
  amount              Float
  currency            String             @default("INR")
  title               String
  category            String
  date                DateTime           @default(now())
  time                String?
  paymentMethod       PaymentMethod
  notes               String?
  receiptImage        String?
  tags                String[]
  isRecurring         Boolean            @default(false)
  recurringFrequency  RecurringFrequency?
  recurringEndDate    DateTime?
  
  // TripSplit linkage
  tripId              String?
  tripName            String?
  expenseId           String?
  settlementId        String?
  isAutoGenerated     Boolean            @default(false)
  myShare             Float?
  totalExpenseAmount  Float?
  splitWith           String[]
  
  // Status
  isDeleted           Boolean            @default(false)
  deletedAt           DateTime?
  locationLat         Float?
  locationLng         Float?
  locationName        String?
  
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([userId, date(sort: Desc)])
  @@index([userId, type, date(sort: Desc)])
  @@index([userId, category, date(sort: Desc)])
  @@index([userId, tripId])
  @@index([userId, isDeleted, date(sort: Desc)])
  @@index([userId, isDeleted, type, date(sort: Desc)])
  @@index([userId, expenseId, isAutoGenerated])
  @@index([userId, settlementId, isAutoGenerated])
}

model Budget {
  id              String           @id @default(uuid())
  userId          String
  month           String           // YYYY-MM
  totalBudget     Float
  totalSpent      Float            @default(0)
  isActive        Boolean          @default(true)
  
  categoryBudgets CategoryBudget[]
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([userId, month])
}

model CategoryBudget {
  id          String  @id @default(uuid())
  budgetId    String
  budget      Budget  @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  category    String
  amount      Float
  spent       Float   @default(0)
  color       String?

  @@unique([budgetId, category])
}

model Bill {
  id              String             @id @default(uuid())
  userId          String
  title           String
  amount          Float
  currency        String             @default("INR")
  dueDate         DateTime
  frequency       RecurringFrequency
  category        String
  autoPay         Boolean            @default(false)
  isActive        Boolean            @default(true)
  isPaid          Boolean            @default(false)
  paidThisMonth   Boolean            @default(false)
  paidAmount      Float?
  lastPaidDate    DateTime?
  nextDueDate     DateTime?
  reminderDays    Int                @default(3)
  notes           String?
  
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([userId, dueDate])
  @@index([userId, isActive, category, dueDate])
  @@index([userId, isPaid, dueDate])
}

model Goal {
  id                  String    @id @default(uuid())
  userId              String
  title               String
  description         String?
  targetAmount        Float
  savedAmount         Float     @default(0)
  currency            String    @default("INR")
  targetDate          DateTime
  category            String
  icon                String    @default("🎯")
  color               String?
  isCompleted         Boolean   @default(false)
  completedAt         DateTime?
  progress            Float     @default(0)
  monthlyContribution Float?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([userId, isCompleted, targetDate])
}

model Debt {
  id            String     @id @default(uuid())
  userId        String
  type          DebtType
  amount        Float
  currency      String     @default("INR")
  friendUserId  String?
  name          String?
  reason        String
  status        DebtStatus @default(pending)
  date          DateTime   @default(now())
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([userId, status])
  @@index([userId, type, status])
}
